{
  "name": "policyscout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PolicyScout — AI insurance quote-shopping & negotiation platform. Person 2 backend foundation: contracts, DB, hashing, privacy, state machine.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
  "scripts": {
    "dev": "next dev -H localhost",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:person3": "vitest run tests/unit/elevenlabs tests/unit/scripts/setup-elevenlabs-agents.test.mjs tests/unit/scripts/prepare-elevenlabs-negotiation.test.mjs tests/unit/scripts/talk-elevenlabs-negotiation.test.mjs tests/unit/scripts/test-elevenlabs-voice.test.mjs tests/unit/scripts/test-elevenlabs-negotiation.test.mjs tests/unit/scripts/verify-elevenlabs-interruption.test.mjs tests/integration/person3-conversations.test.ts",
    "setup:elevenlabs": "node scripts/setup-elevenlabs-agents.mjs",
    "prepare:elevenlabs:negotiation": "node scripts/prepare-elevenlabs-negotiation.mjs",
    "talk:elevenlabs": "UV_CACHE_DIR=.mcp-cache/uv-cache uv run --locked scripts/talk-elevenlabs-negotiation.py",
    "verify:elevenlabs:interruption": "UV_CACHE_DIR=.mcp-cache/uv-cache uv run --locked scripts/verify-elevenlabs-interruption.py",
    "test:elevenlabs:voice": "node scripts/test-elevenlabs-voice.mjs",
    "test:elevenlabs:negotiation": "node scripts/test-elevenlabs-negotiation.mjs",
    "verify:person4": "node scripts/verify-person4-flow.mjs"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "2.58.0",
    "@elevenlabs/react": "1.10.1",
    "@tavily/core": "0.7.6",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@10.30.3"
}
