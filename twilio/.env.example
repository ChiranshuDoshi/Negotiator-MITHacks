# Optional local listener port.
PORT=3010

# Server-only values. Live outbound calls require every variable below.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_PUBLIC_WEBHOOK_BASE_URL=
TWILIO_INTERNAL_API_TOKEN=

# Comma-separated exact E.164 destinations. Do not use wildcards.
TWILIO_OUTBOUND_ALLOWED_DESTINATIONS=

