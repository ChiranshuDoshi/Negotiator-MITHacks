{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/app/*": [
        "./src/app/*"
      ],
      "@/backend/*": [
        "./src/backend/*"
      ],
      "@/domain/negotiation": [
        "./src/backend/negotiator/domain/negotiation"
      ],
      "@/domain/negotiation/*": [
        "./src/backend/negotiator/domain/negotiation/*"
      ],
      "@/domain/handoff": [
        "./src/backend/negotiator/domain/handoff"
      ],
      "@/domain/handoff/*": [
        "./src/backend/negotiator/domain/handoff/*"
      ],
      "@/domain/recommendation": [
        "./src/backend/negotiator/domain/recommendation"
      ],
      "@/domain/recommendation/*": [
        "./src/backend/negotiator/domain/recommendation/*"
      ],
      "@/server/services/conversations": [
        "./src/backend/negotiator/services/conversations"
      ],
      "@/server/services/conversations/*": [
        "./src/backend/negotiator/services/conversations/*"
      ],
      "@/integrations/elevenlabs": [
        "./src/backend/negotiator/integrations/elevenlabs"
      ],
      "@/integrations/elevenlabs/*": [
        "./src/backend/negotiator/integrations/elevenlabs/*"
      ],
      "@/integrations/twilio": [
        "./src/backend/negotiator/integrations/twilio"
      ],
      "@/integrations/twilio/*": [
        "./src/backend/negotiator/integrations/twilio/*"
      ],
      "@/domain/equivalence": [
        "./src/backend/market-research/domain/equivalence"
      ],
      "@/domain/equivalence/*": [
        "./src/backend/market-research/domain/equivalence/*"
      ],
      "@/domain/normalization": [
        "./src/backend/market-research/domain/normalization"
      ],
      "@/domain/normalization/*": [
        "./src/backend/market-research/domain/normalization/*"
      ],
      "@/domain/red-flags": [
        "./src/backend/market-research/domain/red-flags"
      ],
      "@/domain/red-flags/*": [
        "./src/backend/market-research/domain/red-flags/*"
      ],
      "@/domain/research": [
        "./src/backend/market-research/domain/research"
      ],
      "@/domain/research/*": [
        "./src/backend/market-research/domain/research/*"
      ],
      "@/integrations/tavily": [
        "./src/backend/market-research/integrations/tavily"
      ],
      "@/integrations/tavily/*": [
        "./src/backend/market-research/integrations/tavily/*"
      ],
      "@/config/insurance-lines": [
        "./src/backend/shared/config/insurance-lines"
      ],
      "@/config/insurance-lines/*": [
        "./src/backend/shared/config/insurance-lines/*"
      ],
      "@/domain/schemas/*": [
        "./src/backend/shared/schemas/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
