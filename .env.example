# ── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true

# ── Supabase (Person 2) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (optional — extraction/wording) ─────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── ElevenLabs (Person 3) ──────────────────────────────
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_INTAKE_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_CALLER_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_NEGOTIATOR_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_HARBOR_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_GRANITE_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_SUMMIT_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_CEDAR_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_HORIZON_AGENT_ID=

# ── Research (Person 4) ────────────────────────────────
TAVILY_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── Misc ───────────────────────────────────────────────
MAX_UPLOAD_MB=15
DEFAULT_RETENTION_DAYS=30
TAVILY_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_SMOKE_AGENT_ID=
ELEVENLABS_NEGOTIATOR_AGENT_ID=
ELEVENLABS_VOICE_ID=

# Native Twilio calling is configured through ElevenLabs. Import a purchased
# Twilio number or verified caller ID there, then set its non-secret ID below.
ELEVENLABS_TWILIO_PHONE_NUMBER_ID=
# Comma-separated, consented E.164 test destinations. Calls are rejected until
# this list includes the requested number.
TWILIO_OUTBOUND_ALLOWED_DESTINATIONS=

# Temporary server-to-server authorization for Person 4 API routes.
# Replace with Person 2's authenticated workflow ownership checks during integration.
POLICYSCOUT_INTERNAL_API_KEY=

DEMO_MODE=true
